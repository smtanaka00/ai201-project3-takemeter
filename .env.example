# TakeMeter — local environment template.
# Copy this file to `.env` and fill in real values. `.env` is gitignored; never commit it.
#
# NOTE: the scraper uses Reddit's public JSON endpoints and needs NO credentials, so this
# file is only relevant if you choose to run the Groq baseline locally instead of in Colab.

# Groq API key — only needed if you run the zero-shot baseline outside Colab.
# In Colab, store this as a Secret named GROQ_API_KEY (see the notebook) instead.
GROQ_API_KEY=your_groq_key_here
